{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "color": {
      "palette": [
        {
          "slug": "ips-background",
          "color": "#F7F7F7",
          "name": "IPS Fundo Claro"
        },
        {
          "slug": "ips-background-warm",
          "color": "#F4EEE8",
          "name": "IPS Fundo Quente"
        },
        {
          "slug": "ips-background-alt",
          "color": "#E1E2DB",
          "name": "IPS Fundo Alternativo"
        },
        {
          "slug": "ips-neutral",
          "color": "#D8D3CE",
          "name": "IPS Neutro"
        },
        {
          "slug": "ips-primary",
          "color": "#C39B7C",
          "name": "IPS Destaque Suave"
        },
        {
          "slug": "ips-primary-dark",
          "color": "#AB7942",
          "name": "IPS Castanho Dourado"
        },
        {
          "slug": "ips-foreground",
          "color": "#0B0620",
          "name": "IPS Texto Escuro"
        }
      ]
    },
    "layout": {
      "contentSize": "780px",
      "wideSize": "1320px"
    },
    "spacing": {
      "units": ["px", "em", "rem", "%", "vw", "vh"]
    }
  },
  "styles": {
    "color": {
      "background": "#F7F7F7",
      "text": "#0B0620"
    },
    "elements": {
      "link": {
        "color": {
          "text": "#0B0620"
        }
      }
    }
  },
  "templateParts": [
    {
      "area": "header",
      "name": "header",
      "title": "Header IPS"
    },
    {
      "area": "footer",
      "name": "footer",
      "title": "Footer IPS"
    }
  ]
}
